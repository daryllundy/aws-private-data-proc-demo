[bastion]
bastion1 ansible_host=BASTION_PUBLIC_IP ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/KEY.pem

[processors]
processor1 ansible_host=PRIVATE_INSTANCE_IP ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/KEY.pem

[processors:vars]
ansible_ssh_common_args='-o ProxyJump=ec2-user@BASTION_PUBLIC_IP'
